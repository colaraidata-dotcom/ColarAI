# Supabase — https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service role key (server-side only, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# DNS Worker URL (deployed Cloudflare Worker)
DNS_RESOLVER_URL=https://guardian-dns-worker.talipclk1988.workers.dev/dns-query

# DNS Worker shared secret (generate with: openssl rand -hex 32)
DNS_WORKER_SECRET=YOUR_DNS_WORKER_SECRET

# Resend — https://resend.com → API Keys
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM=Guardian <noreply@yourdomain.com>

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Stripe — https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
